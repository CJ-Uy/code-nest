# ------------------------------------------------------------
# App environment
# ------------------------------------------------------------

# Controls which backend mode the app uses.
# local = use local dev resources or local fallbacks.
# shared = use shared dev resources through an internal API and/or dev R2 credentials.
# production = use Cloudflare bindings directly.
APP_ENV=local

# Controls which storage adapter is used.
# local = local filesystem storage.
# api = storage through the shared dev internal API.
# r2-s3 = R2 using S3-compatible credentials, usually for shared dev.
# binding = Cloudflare R2 binding, usually production only.
STORAGE_MODE=local

# Allows production to use STORAGE_MODE instead of the BUCKET binding.
# Leave blank unless you are running a documented emergency procedure.
ALLOW_PRODUCTION_STORAGE_MODE_OVERRIDE=

# ------------------------------------------------------------
# Shared dev API
# ------------------------------------------------------------

# Base URL for the internal shared development API.
# Used when APP_ENV=shared.
SHARED_API_BASE_URL=

# Bearer token for the shared development API.
# Used when APP_ENV=shared.
# Keep this secret.
SHARED_API_TOKEN=

# ------------------------------------------------------------
# R2 S3-compatible storage
# ------------------------------------------------------------

# Cloudflare account ID used for the R2 S3-compatible endpoint.
# Used when STORAGE_MODE=r2-s3.
R2_ACCOUNT_ID=

# R2 bucket name for development uploads.
# This should be a dev bucket, not production.
R2_BUCKET_NAME=

# R2 S3-compatible access key ID.
# Used only for local/shared development.
# Keep this secret.
R2_ACCESS_KEY_ID=

# R2 S3-compatible secret access key.
# Used only for local/shared development.
# Keep this secret.
R2_SECRET_ACCESS_KEY=

# R2 S3-compatible endpoint.
# Usually: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=

# ------------------------------------------------------------
# Local fallback storage/database
# ------------------------------------------------------------

# Path to the local SQLite database used when Cloudflare D1 bindings
# are not available during local development.
LOCAL_SQLITE_PATH=./.local/dev.db

# Directory for local file uploads when not using R2.
LOCAL_STORAGE_DIR=./.local/uploads
