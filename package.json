{
	"name": "code-nest",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build && opennextjs-cloudflare build --skipNextBuild",
		"start": "next start",
		"lint": "eslint .",
		"deploy": "pnpm build && opennextjs-cloudflare deploy",
		"upload": "pnpm build && opennextjs-cloudflare upload",
		"preview": "pnpm build && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
	},
	"dependencies": {
		"@opennextjs/cloudflare": "^1.19.9",
		"@radix-ui/react-slot": "^1.2.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.17.0",
		"next": "16.2.6",
		"react": "^19.1.7",
		"react-dom": "^19.1.7",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19.1.7",
		"@types/react-dom": "^19.1.7",
		"eslint": "^9",
		"eslint-config-next": "16.2.6",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"wrangler": "^4.98.0"
	}
}
