{
	"name": "code-nest",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"dev:cf": "pnpm build && wrangler dev --env dev",
		"clean:opennext": "node -e \"require('node:fs').rmSync('.open-next',{recursive:true,force:true})\"",
		"build": "next build && pnpm clean:opennext && opennextjs-cloudflare build --skipNextBuild",
		"start": "next start",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"deploy": "pnpm deploy:prod",
		"deploy:dev": "pnpm build && pnpm upload:dev",
		"deploy:prod": "pnpm build && pnpm upload:prod",
		"upload": "pnpm upload:prod",
		"upload:dev": "wrangler deploy --env dev",
		"upload:prod": "wrangler deploy --env=\"\"",
		"preview": "pnpm build && opennextjs-cloudflare preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply DB --local",
		"db:migrate:local:sqlite": "tsx src/db/migrate-local-sqlite.ts",
		"db:migrate:dev": "wrangler d1 migrations apply DB --env dev --remote",
		"db:migrate:prod": "wrangler d1 migrations apply code-nest-prod-db --remote",
		"db:seed:local": "tsx src/db/seed/run.ts local",
		"db:seed:dev": "tsx src/db/seed/run.ts dev",
		"db:seed:dev:export": "tsx scripts/export-seed-sql.ts",
		"db:studio": "drizzle-kit studio",
		"check:shared-dev-note": "tsx scripts/check-shared-dev-note.ts",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"cf-typegen:dev": "wrangler types --env dev --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"cf-typegen:prod": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
	},
	"dependencies": {
		"@auth/drizzle-adapter": "^1.11.2",
		"@aws-sdk/client-s3": "^3.1065.0",
		"@aws-sdk/s3-request-presigner": "^3.1065.0",
		"@opennextjs/cloudflare": "^1.19.9",
		"@radix-ui/react-checkbox": "^1.3.5",
		"@radix-ui/react-slot": "^1.2.4",
		"better-sqlite3": "^12.10.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"lucide-react": "^1.17.0",
		"next": "16.2.6",
		"next-auth": "5.0.0-beta.31",
		"qrcode": "^1.5.4",
		"radix-ui": "^1.6.0",
		"react": "^19.1.7",
		"react-dom": "^19.1.7",
		"tailwind-merge": "^3.6.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.16.16",
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^20",
		"@types/qrcode": "^1.5.6",
		"@types/react": "^19.1.7",
		"@types/react-dom": "^19.1.7",
		"@vitest/coverage-v8": "^4.1.9",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9",
		"eslint-config-next": "16.2.6",
		"tailwindcss": "^4",
		"tsx": "^4.22.4",
		"typescript": "^5.7.4",
		"vitest": "^4.1.9",
		"wrangler": "^4.98.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"esbuild",
			"sharp",
			"unrs-resolver",
			"workerd"
		]
	}
}
