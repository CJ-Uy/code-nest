{
	"name": "code-nest",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"dev:cf": "pnpm build && wrangler dev --env dev",
		"build": "next build && opennextjs-cloudflare build --skipNextBuild",
		"start": "next start",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"deploy": "pnpm deploy:prod",
		"deploy:dev": "pnpm build && wrangler deploy --env dev",
		"deploy:prod": "pnpm build && wrangler deploy --env=\"\"",
		"upload": "pnpm build && opennextjs-cloudflare upload",
		"preview": "pnpm build && opennextjs-cloudflare preview",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply code-nest-dev-db --local",
		"db:migrate:dev": "wrangler d1 migrations apply DB --env dev --remote",
		"db:migrate:prod": "wrangler d1 migrations apply code-nest-prod-db --remote",
		"db:studio": "drizzle-kit studio",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"cf-typegen:dev": "wrangler types --env dev --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"cf-typegen:prod": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1065.0",
		"@aws-sdk/s3-request-presigner": "^3.1065.0",
		"@opennextjs/cloudflare": "^1.19.9",
		"@radix-ui/react-slot": "^1.2.4",
		"better-sqlite3": "^12.10.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"lucide-react": "^1.17.0",
		"next": "16.2.6",
		"react": "^19.1.7",
		"react-dom": "^19.1.7",
		"tailwind-merge": "^3.6.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^20",
		"@types/react": "^19.1.7",
		"@types/react-dom": "^19.1.7",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9",
		"eslint-config-next": "16.2.6",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"wrangler": "^4.98.0"
	}
}
